import rechner          # import rechner bedeutet dass Python jetzt nach einer Datei names rechner.py sucht
                        # -> wenn es rechner.py gefunden hat -> macht Python deren Inhalt in der main.py verfügbar
                        
ergebnis = rechner.addieren(5, 3)   # rechner.addieren -> wir sagen Python dass es die Funktion addieren aus der Datei rechner.py verwenden soll.
# rechner.addieren -> rechner steht für die Datei rechner.py + Funktion addieren in dieser Datei
# (5, 3) -> Argumente die die Parameter a und b in der Funktion addieren zugewiesen werden

print(ergebnis)    # Ausgabe: 8

